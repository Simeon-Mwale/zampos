# ⚡ Voltage Cloud Configuration
VOLTAGE_API_URL=https://api.voltage.cloud
VOLTAGE_API_KEY=your_voltage_api_key_here
VOLTAGE_ORG_ID=your_org_id_here
VOLTAGE_NETWORK=mutinynet  # Switch to 'mainnet' for production

# 🌐 App Configuration
DATABASE_PATH=./data/zampos.db
FRONTEND_URL=https://zampos.zm  # Production URL
WEBHOOK_URL=https://zampos.zm/api/webhook/voltage  # Public webhook endpoint

# 💱 Rate Service (CoinGecko or your own)
RATE_API_URL=https://api.coingecko.com/api/v3
RATE_CACHE_SECONDS=60

# 🔐 Security
API_SECRET_KEY=your_fastapi_secret_key_here
CORS_ORIGINS=["https://zampos.zm","https://www.zampos.zm"]

# 📡 Monitoring (optional)
LOG_LEVEL=INFO
SENTRY_DSN=  # Optional: add for error tracking


# Exchange Rate APIs
FX_API_BASE_URL=https://v6.exchangerate-api.com/v6
FX_API_KEY=your_free_key_here  # Get at https://www.exchangerate-api.com/

# Rate caching
RATE_CACHE_TTL_SECONDS=45

# Existing vars...
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
NODE_REST_HOST=your-node.m.voltage.cloud
NODE_MACAROON_HEX=your_macaroon_hex