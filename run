git checkout develop


# Stay on develop for all new features
git checkout develop

# Make changes to frontend code
# Test locally first!
cd frontend
npm run build  # Must succeed

# Commit and push to develop
cd ..
git add .
git commit -m "feat: your new feature"
git push origin develop

develop branch (test)  →  Vercel preview URL (test only)
         ↓
   (merge when ready)
         ↓
main branch (production) → zampos.vercel.app (live users)